# 数据库（必须与 nodeskclaw-backend/.env 中的 DATABASE_URL 保持一致）
# 复制 .env.example 为 .env 后，将下面的值替换成 backend 实际使用的连接串
DATABASE_URL=postgresql+asyncpg://nodeskclaw:nodeskclaw123@localhost:5432/nodeskclaw_rbac

# 出站代理（用于访问 OpenAI/Anthropic 等外部 API）
HTTPS_PROXY=http://localhost:7890

# 是否记录完整请求体（request_body），默认关闭
LLM_LOG_CONTENT=false

# Codex CLI 集成（可选）
CODEX_COMMAND=codex
CODEX_HOME=
CODEX_SKIP_GIT_REPO_CHECK=true
CODEX_BYPASS_APPROVALS_AND_SANDBOX=false
CODEX_TIMEOUT_SECONDS=300
